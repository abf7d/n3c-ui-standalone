{
  "name": "n3c-ui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "n3c": "ng serve --project=n3c-app",
    "test:local": "cross-env CYPRESS_ENV=local npx cypress run --browser chrome",
    "test:dev": "cross-env CYPRESS_ENV=dev npx cypress run --browser chrome",
    "test:demo": "cross-env CYPRESS_ENV=dev npx cypress run --browser chrome",
    "test:qa": "cross-env CYPRESS_ENV=qa npx cypress run --browser chrome",
    "test:prod": "cross-env CYPRESS_ENV=prod npx cypress run --browser chrome",
    "open:local": "cross-env CYPRESS_ENV=local npx cypress open",
    "open:dev": "cross-env CYPRESS_ENV=dev npx cypress run open",
    "open:demo": "cross-env CYPRESS_ENV=demo npx cypress run open",
    "open:qa": "cross-env CYPRESS_ENV=qa npx cypress run open",
    "open:prod": "cross-env CYPRESS_ENV=prod npx cypress open",
    "prettier": "prettier \"**/*.ts\" \"**/*.js\" \"**/*.md\"",
    "prettier:check": "npm run prettier -- -l",
    "prettier:cli": "npm run prettier -- -c",
    "prettier:fix": "npm run prettier:cli -- --write",
    "prepare": "husky install",
    "generate:lib": "node tools/create-internal-lib.cjs"

  },
  "private": true,
  "packageManager": "npm@11.6.1",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*.{ts,html}": [
      "eslint --config eslint.config.js --cache --fix",
      "prettier --write -u"
    ]
  }
}
