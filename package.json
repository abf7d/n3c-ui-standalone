{
  "name": "n3c-ui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "n3c": "ng serve --project=n3c-app",
    "test:local": "cross-env CYPRESS_ENV=local npx cypress run --browser chrome",
    "test:dev": "cross-env CYPRESS_ENV=dev npx cypress run --browser chrome",
    "test:demo": "cross-env CYPRESS_ENV=dev npx cypress run --browser chrome",
    "test:qa": "cross-env CYPRESS_ENV=qa npx cypress run --browser chrome",
    "test:prod": "cross-env CYPRESS_ENV=prod npx cypress run --browser chrome",
    "open:local": "cross-env CYPRESS_ENV=local npx cypress open",
    "open:dev": "cross-env CYPRESS_ENV=dev npx cypress run open",
    "open:demo": "cross-env CYPRESS_ENV=demo npx cypress run open",
    "open:qa": "cross-env CYPRESS_ENV=qa npx cypress run open",
    "open:prod": "cross-env CYPRESS_ENV=prod npx cypress open",
    "prettier": "prettier \"**/*.ts\" \"**/*.js\" \"**/*.md\"",
    "lint": "npm run prettier:check && npm run lint:eslint",
    "lint:eslint": "eslint --config eslint.config.js --cache .",
    "lint:eslint:fix": "eslint --config eslint.config.js --cache --fix .",
    "lint:fix": "npm run lint:eslint:fix && npm run prettier:fix",
    "prettier:check": "npm run prettier -- -l",
    "prettier:cli": "npm run prettier -- -c",
    "prettier:fix": "npm run prettier:cli -- --write",
    "prepare": "husky install",
    "generate:lib": "node tools/create-internal-lib.cjs"
  },
  "private": true,
  "packageManager": "npm@11.6.1",
  "dependencies": {
    "@angular/animations": "^21.2.8",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^20.2.14",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "ag-grid-angular": "^33.3.2",
    "ag-grid-community": "^33.3.2",
    "bootstrap": "^5.0.0",
    "countup.js": "^2.8.0",
    "d3": "^7.8.5",
    "date-fns": "^2.30.0",
    "file-saver": "^2.0.5",
    "font-awesome": "^4.7.0",
    "html-to-image": "^1.11.11",
    "marked": "^14.1.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/eslintrc": "^3.3.0",
    "@eslint/js": "^9.21.0",
    "@types/d3": "^7.4.3",
    "@types/file-saver": "^2.0.7",
    "@types/topojson-client": "^3.1.5",
    "angular-eslint": "18.3.1",
    "cypress": "^13.7.3",
    "eslint": "^9.9.1",
    "husky": "^8.0.0",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.15.0",
    "vitest": "^4.0.8"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*.{ts,html}": [
      "eslint --config eslint.config.js --cache --fix",
      "prettier --write -u"
    ]
  }
}
